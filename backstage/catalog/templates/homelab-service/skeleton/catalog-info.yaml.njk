apiVersion: backstage.io/v1alpha1
kind: Component
metadata:
  name: {{ values.serviceName }}
  description: {{ values.serviceDescription }}
  annotations:
    homelab.dev/tier: {{ values.tier }}
    homelab.dev/criticality: {{ values.criticality }}
    homelab.dev/runbook: {{ values.runbookPath }}
    homelab.dev/gitea-repo: {{ values.giteaRepo }}
  links:
    - url: {{ values.serviceUrl }}
      title: Service URL
    - url: {{ values.sourceDirectoryUrl }}
      title: Source Directory
    - url: https://gitea.homelabdev.space/{{ values.giteaRepo }}/actions
      title: CI/CD (Gitea Actions)
spec:
  type: service
  lifecycle: {{ values.lifecycle }}
  owner: {{ values.owner }}
  system: homelab
