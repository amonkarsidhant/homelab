        <mxCell id="note" value="Important: NVIDIA does not publish endpoint-specific benchmark tables for free-tier variants.&#xa;Numbers below are practical ranking + public model-family signals, not official NVIDIA endpoint scores." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9C3;strokeColor=#CA8A04;fontColor=#713F12;fontSize=13;" vertex="1" parent="1">
