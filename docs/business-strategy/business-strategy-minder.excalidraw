      "width": 350,
      "height": 120,
      "angle": 0,
      "strokeColor": "#0052cc",
      "backgroundColor": "#eff6ff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "roundness": { "x": 6, "y": 6 },
      "seed": 71,
