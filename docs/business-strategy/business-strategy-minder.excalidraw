      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "seed": 92,
      "version": 1,
      "versionNonce": 92,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "Traction milestones:\n\n① Ship micro-product\n   (Failure Prediction Engine v0.1)\n\n② Write 3 YouTube videos\n   on resilience methodology\n\n③ Get 5 design partners\n   (Worldline + 4 external)\n\n④ OSS release + community\n\n⑤ Paid tier for enterprise\n   integrations + AI layer\n\nValidate before building.",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10
    },

    {
      "id": "col8-header",
