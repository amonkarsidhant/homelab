    },
    {
      "id": "moat-text",
      "type": "text",
      "x": 50,
      "y": 560,
      "width": 480,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "seed": 62,
      "version": 1,
      "versionNonce": 62,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "The moat isn't the AI — it's what the AI learns:\n\n① Proprietary failure patterns from customer incidents\n   (network effect — more customers = smarter predictions)\n\n② Integration depth — connects to Prometheus, Grafana,\n   PagerDuty, k8s, GitHub, Opsgenie, etc.\n   (harder to rip out than to adopt)\n\n③ Domain expertise you already have — you speak SRE,\n   chaos engineering, resilience fluently\n\n④ Early adopters as partners — Worldline could be\n   design partner + first reference customer",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10
    },

    {
      "id": "speed-header",
      "type": "text",
      "x": 40,
      "y": 710,
      "width": 500,
      "height": 24,
      "angle": 0,
