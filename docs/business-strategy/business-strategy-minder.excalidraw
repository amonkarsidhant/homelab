    {
      "id": "gtm-text",
      "type": "text",
      "x": 440,
      "y": 320,
      "width": 330,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "seed": 62,
      "version": 1,
      "versionNonce": 62,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "YouTube is the forcing function AND audience builder:\n\n▶ n8n model: content + OSS first, product second\n   → Build in public, document the methodology\n\n▶ \"Chaos Engineering 101\" / \"Resilience Testing for devs\"\n   → Proves expertise before product exists\n\n▶ Ship Resilience Agent v0.1 → demo it on YouTube\n   → Audience grows WITH the product\n\n▶ Community (not just buyers) = early loyalty",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10
    },

