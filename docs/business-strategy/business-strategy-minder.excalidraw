      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "① Build ONE micro-product — smallest thing that works\n② Open-source the core agent — builds community + credibility\n③ Charge for the AI layer (SaaS) — inference, predictions, dashboards\n④ Target: startups + SMBs with k8s, no SRE team\n\nMVP in: 2-3 months | First paying customer: 3-6 months",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10
    },

