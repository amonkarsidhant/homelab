    },
    {
      "id": "opencore-text",
      "type": "text",
      "x": 440,
      "y": 480,
      "width": 330,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "seed": 82,
      "version": 1,
      "versionNonce": 82,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "OSS Core (free)              Closed Premium (paid)\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nFailure detection agents      AI prediction engine\nResilience scoring             Proprietary failure patterns\nExport to Prometheus/Grafana   Custom ML on customer data\nCommunity playbooks            Enterprise integrations (PagerDuty,\nOpen metric standards          ServiceNow, Okta)\n                              SLA/SLO predictive models\n\nTrust builder → switching cost → enterprise sales",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10
    },

    {
      "id": "col7-header",
