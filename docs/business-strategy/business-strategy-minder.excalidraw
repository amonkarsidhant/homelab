    {
      "id": "opencore-text",
      "type": "text",
      "x": 50,
      "y": 470,
      "width": 330,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "seed": 72,
      "version": 1,
      "versionNonce": 72,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "OSS Core = COMMUNITY (builds the moat)      Paid = VELOCITY (saves time)\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nResilience scoring algorithms        AIRecommender — proprietary ML on\nMicro-chaos experiment library       customer failure patterns\nExport to Prometheus/Grafana       Enterprise integrations\nCommunity playbooks (GitHub)        (PagerDuty, ServiceNow, Okta)\nOpen failure pattern taxonomy       SLA/SLO predictive models\n                                    Priority support + SLA\n\nTrust builder → switching cost → enterprise revenue",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10
    },

    {
      "id": "col6-header",
