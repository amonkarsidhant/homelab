      "versionNonce": 71,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false
    },
    {
      "id": "content-text",
      "type": "text",
      "x": 50,
      "y": 470,
      "width": 330,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "seed": 72,
      "version": 1,
      "versionNonce": 72,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "YouTube as a forcing function + audience builder:\n\n▶ Build in public — document the methodology\n   → Proves domain expertise before product exists\n\n▶ \"Chaos Engineering 101\" / \"Resilience Testing for devs\"\n   → SEO + trust + creator economy angle\n\n▶ Show the product BEING built, not just demo'd\n   → Audience grows WITH the product\n\n▶ Seed community: practitioners who want to learn,\n   not just buyers — loyalty before monetization",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10
    },

    {
      "id": "col6-header",
      "type": "text",
