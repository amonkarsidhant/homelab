      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "seed": 102,
      "version": 1,
      "versionNonce": 102,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "⚠ CodRabitt / Qodo could expand here\n   → They focus on CODE layer. Different swim lane — but worth watching.\n\n⚠ Microsoft / Google could enter\n   → Enterprise sales cycles are 12-18 months. We ship in weeks.\n\n⚠ We need to validate: do teams actually want this, or is it cool-to-have?\n\n✓ Our speed advantage: ship fast, iterate, niche down\n✓ Target: startups + SMBs with k8s who can't afford full SRE teams",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10
    },

