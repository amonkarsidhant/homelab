      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false
    },
    {
      "id": "moat-text",
      "type": "text",
      "x": 440,
      "y": 310,
      "width": 330,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "seed": 62,
      "version": 1,
      "versionNonce": 62,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "The moat isn't just the AI — it's what the AI learns:\n\n① Proprietary failure patterns from customer incidents\n   → More customers = smarter predictions (network effect)\n\n② Integration depth (Prometheus, Grafana, PagerDuty, k8s)\n   → Harder to rip out than to adopt\n\n③ Our domain expertise — we already speak SRE, chaos\n   engineering, resilience fluently\n\n④ Worldline could be design partner + first reference",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10
    },

    {
      "id": "col5-header",
      "type": "text",
      "x": 40,
      "y": 430,
      "width": 350,
      "height": 24,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "seed": 70,
      "version": 1,
      "versionNonce": 70,
      "isDeleted": false,
      "boundElements": null,
      "updated": 0,
      "link": null,
      "locked": false,
      "text": "05 — Content & Community",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 10
    },
    {
      "id": "content-box",
