# Backup configuration
# Copy to ~/.config/homelab/backup.env and fill in your values

# GPG passphrase for encrypting backups (generate with: gpg --gen-random --armor 1 32)
BACKUP_PASSPHRASE=

# Tailscale VPN IPs (add after running install-tailscale.sh)
DEST_PI=
DEST_PI_USER=
DEST_PI_PATH=/home/sidhant/backups

DEST_MAC=
DEST_MAC_USER=
DEST_MAC_PATH=/Users/sidhant/backups

# Backup retention (days)
RETENTION_DAYS=30

# GitHub mirror is auto-pushed via homelab git remote (no token needed here)
